  "shortcuts": [
    {
      "name": "Tableau de bord",
      "short_name": "Accueil",
      "description": "Vue d'ensemble de la scolarité",
      "url": "/index.html#dashboard",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Cotes et Notes",
      "short_name": "Notes",
      "description": "Consulter les notes et cotes",
      "url": "/index.html#grades",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Présences",
      "short_name": "Présences",
      "description": "Suivi des présences et incidents",
      "url": "/index.html#presence-incidents",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Communiqués",
      "short_name": "Infos",
      "description": "Consulter les communiqués",
      "url": "/index.html#communiques",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Paiements",
      "short_name": "Paiements",
      "description": "Gérer les paiements",
      "url": "/index.html#payments",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Devoirs",
      "short_name": "Devoirs",
      "description": "Consulter les devoirs",
      "url": "/index.html#homework",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Emploi du temps",
      "short_name": "Horaires",
      "description": "Voir l'emploi du temps",
      "url": "/index.html#timetable",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Notifications",
      "short_name": "Alertes",
      "description": "Voir les notifications",
      "url": "/index.html#notifications",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+csapp",
      "url": "/index.html?action=%s"
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  },

  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".jpg", ".jpeg", ".png", ".gif"]
      }
    }
  ],

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "handle_links": "preferred",
  
  "prefer_related_applications": false,

  "permissions": {
    "notifications": {
      "description": "Recevoir des alertes pour les notes, incidents, paiements"
    },
    "camera": {
      "description": "Prendre des photos pour le profil"
    }
  },

  "features": [
    {
      "name": "Biometric Authentication",
      "description": "Connexion par Face ID / Touch ID"
    },
    {
      "name": "Offline Mode",
      "description": "Consultation hors ligne des données"
    },
    {
      "name": "Push Notifications",
      "description": "Alertes en temps réel"
    }
  ],

  "note": "Application PWA pour le suivi scolaire - CS la Colombe",
  "version": "2.1.0",
  "developer": {
    "name": "CS la Colombe",
    "url": "https://cs-lacolombe.edu"
  }
}